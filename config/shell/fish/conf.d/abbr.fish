# NOTE: manage fish abbreviations
# https://fishshell.com/docs/current/cmds/abbr.html

abbr c clear
abbr cl clear
abbr claer clear
abbr clera clear
abbr cx "chmod +x"
abbr e exit
abbr lg lazygit
abbr fi "fisher install"
abbr fr "fisher refresh"
abbr fu "fisher update"
abbr fl "fisher list | sed 's/.*/"&"/'"