{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "palette": {
        "terminalBg": "#303446"
    },
    "blocks": [
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "foreground": "white",
                    "style": "plain",
                    "type": "text"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "leading_diamond": "\ue0b6",
                    "trailing_diamond": "\ue0b0",
                    "background": "blue",
                    "foreground": "p:terminalBg",
                    "properties": {
                        "home_icon": "\ueb06 ",
                        "style": "agnoster_short"
                    },
                    "style": "diamond",
                    "template": " {{ .Path }} ",
                    "type": "path"
                },
                {
                    "background": "cyan",
                    "foreground": "p:terminalBg",
                    "leading_diamond": "<transparent,cyan>\ue0b0</>",
                    "trailing_diamond": "\ue0b0",
                    "properties": {
                        "fetch_stash_count": false,
                        "fetch_status": true,
                        "fetch_upstream_icon": false,
                        "branch_icon": "\uf418 ",
                        "github_icon": "\uea84 ",
                        "branch_max_length": 20,
                        "truncate_symbol": ".."
                    },
                    "style": "diamond",
                    "template": " {{ .HEAD }} ",
                    "type": "git"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "right",
            "segments": [
                {
                    "background": "blue",
                    "foreground": "p:terminalBg",
                    "invert_powerline": true,
                    "leading_diamond": "\ue0b2",
                    "properties": {
                        "charged_icon": "",
                        "charging_icon": "\ueb2d ",
                        "discharging_icon": "\uea9a "
                    },
                    "style": "diamond",
                    "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }}% <transparent>\ue0b2</>",
                    "type": "battery"
                },
                {
                    "background": "blue",
                    "foreground": "p:terminalBg",
                    "invert_powerline": true,
                    "leading_diamond": "\ue0b2",
                    "properties": {
                        "always_enabled": false,
                        "threshold": 1000
                    },
                    "style": "diamond",
                    "template": " \uead8 {{ .FormattedMs }} <transparent>\ue0b2</>",
                    "type": "executiontime"
                },
                {
                    "background": "blue",
                    "foreground": "p:terminalBg",
                    "invert_powerline": true,
                    "leading_diamond": "\ue0b2",
                    "properties": {
                        "time_format": "_2,15:04"
                    },
                    "style": "diamond",
                    "template": " \ueab0 {{ .CurrentDate | date .Format }}",
                    "trailing_diamond": "\ue0b4",
                    "type": "time"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "foreground": "magenta",
                    "style": "plain",
                    "template": "{{ if gt .Code 0 }} <red>\uea9c</> {{ else }} <magenta>\uea9c</> {{ end }}",
                    "type": "text"
                }
            ],
            "type": "prompt"
        }
    ],
    "console_title_template": "{{if .Root}}Admin: {{end}} {{.Folder}}",
    "final_space": true,
    "version": 2
}
