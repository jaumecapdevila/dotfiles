background-blur-radius = 20
background-opacity = 0.9

confirm-close-surface=false
cursor-style = bar
cursor-style-blink = true

font-family = "OperatorMono Nerd Font"
font-size = 17
font-style = "Book"
font-style-bold = "Bold"
font-style-bold-italic = "Bold Italic"
