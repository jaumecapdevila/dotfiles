macos-non-native-fullscreen = true
macos-option-as-alt = left
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = transparent

term = xterm-256color
theme = catppuccin-mocha
title = "Ghostty"

window-padding-balance = true
window-padding-x = 16
window-padding-y = 10
