{
  "assistant": {
    "button": false,
    "version": "1"
  },
  "autosave": "on_focus_change",
  "base_keymap": "VSCode",
  "buffer_font_family": "Operator Mono",
  "buffer_font_features": {
    "liga": false
  },
  "buffer_font_size": 17,
  "buffer_font_weight": 300,
  "calls": {
    "mute_on_join": true,
    "share_on_join": false
  },
  "chat_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "cursor_blink": true,
  "ensure_final_newline_on_save": true,
  "experimental.theme_overrides": {
    "border.variant": "#ffcc66",
    "elevated_surface.background": "#171c28",
    "ghost_element.hover": "#2f3b54",
    "ghost_element.selected": "#2f3b54",
    "editor.subheader.background": "#2f3b54",
    "error.background": "#e454541b",
    "error.border": "#e454541b",
    "warning.background": "#ff942f1b",
    "warning.border": "#ff942f1b",
    "info.background": "#00b7e420",
    "info.border": "#00b7e420",
    "hint.background": "#17a2a220",
    "hint.border": "#00b7e420",
    "syntax": {
      "constant": {
        "font_style": "normal",
        "font_weight": 600
      },
      "keyword": {
        "font_style": "italic",
        "font_weight": 600
      }
    }
  },
  "format_on_save": "on",
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false
    }
  },
  "indent_guides": {
    "background_coloring": "indent_aware",
    "coloring": "disabled"
  },
  "linked_edits": true,
  "notification_panel": {
    "button": false
  },
  "project_panel": {
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "button": false,
    "dock": "right"
  },
  "relative_line_numbers": true,
  "remove_trailing_whitespace_on_save": true,
  "scroll_beyond_last_line": "off",
  "scrollbar": {
    "show": "auto"
  },
  "show_wrap_guides": false,
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "tab_size": 2,
  "terminal": {
    "font_family": "PragmataProMono Nerd Font",
    "font_size": 17,
    "font_weight": 400
  },
  "theme": "Halcyon",
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "ui_font_size": 17,
  "vertical_scroll_margin": 0,
  "vim_mode": true
}
