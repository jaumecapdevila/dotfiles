{
  "assistant_v2": {
    "enabled": false
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "autosave": "on_focus_change",
  "base_keymap": "VSCode",
  "buffer_font_family": "Dank Mono",
  "buffer_font_features": {
    "liga": true
  },
  "buffer_font_size": 17,
  "chat_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "cursor_blink": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false
    }
  },
  "inlay_hints": {
    "chaining_hints": true,
    "max_len": 80,
    "parameter_hints": true,
    "type_hints": true
  },
  "project_panel": {
    "auto_fold_dirs": true,
    "button": false,
    "dock": "right"
  },
  "relative_line_numbers": true,
  "remove_trailing_whitespace_on_save": true,
  "scrollbar": {
    "show": "never"
  },
  "show_wrap_guides": false,
  "tab_size": 2,
  "terminal": {
    "font_family": "DankMono Nerd Font",
    "font_size": 17
  },
  "theme": "Tokyo Night Storm",
  // "ui_font_family": "Dank Mono",
  "ui_font_size": 17,
  "vertical_scroll_margin": 0,
  "vim_mode": true,
  "experimental.theme_overrides": {}
}
