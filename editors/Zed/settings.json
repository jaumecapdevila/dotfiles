{
  "assistant": {
    "button": true,
    "default_model": {
      "model": "gpt-4o",
      "provider": "copilot_chat"
    },
    "dock": "left",
    "version": "2"
  },
  "autosave": "on_focus_change",
  "base_keymap": "VSCode",
  "buffer_font_family": "Operator Mono",
  "buffer_font_features": {
    "liga": false
  },
  "active_pane_modifiers": {
    "border_size": 1,
    "inactive_opacity": 0.5
  },
  "buffer_font_size": 17,
  "buffer_font_weight": 300,
  "calls": {
    "mute_on_join": true,
    "share_on_join": false
  },
  "centered_layout": {
    "centered": true
  },
  "chat_panel": {
    "button": false,
    "dock": "left"
  },
  "collaboration_panel": {
    "button": false,
    "dock": "bottom"
  },
  "cursor_blink": true,
  "cursor_shape": "bar",
  "ensure_final_newline_on_save": true,
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },
  "format_on_save": "on",
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false
    }
  },
  "indent_guides": {
    "background_coloring": "indent_aware",
    "coloring": "disabled",
    "enabled": true
  },
  "inlay_hints": {
    "enabled": false,
    "show_background": false
  },
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "Python": {
      "format_on_save": {
        "language_server": {
          "name": "ruff"
        }
      },
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      },
      "language_servers": ["pyright", "ruff"]
    },
    "TSX": {
      "code_actions_on_format": {
        "source.organizeImports": true
      }
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.organizeImports": true
      },
      "inlay_hints": {
        "enabled": false,
        "show_other_hints": true,
        "show_parameter_hints": false,
        "show_type_hints": true
      }
    }
  },
  "linked_edits": true,
  "notification_panel": {
    "button": false,
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right",
    "indent_guides": {
      "show": "never"
    }
  },
  "project_panel": {
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "button": false,
    "dock": "left",
    "folder_icons": true,
    "indent_guides": {
      "show": "never"
    },
    "indent_size": 20,
    "scrollbar": {
      "show": "never"
    }
  },
  "relative_line_numbers": true,
  "remove_trailing_whitespace_on_save": true,
  "scroll_beyond_last_line": "off",
  "scrollbar": {
    "show": "never"
  },
  "show_wrap_guides": false,
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false
  },
  "tab_size": 2,
  "tabs": {
    "activate_on_close": "history",
    "file_icons": true,
    "git_status": false
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "dock": "bottom",
    "font_family": "OperatorMono Nerd Font",
    "font_size": 17,
    "font_weight": 300
  },
  "theme": "Rosé Pine Moon",
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false
  },
  "ui_font_family": "Operator Mono",
  "ui_font_size": 17,
  "ui_font_weight": 400,
  "vertical_scroll_margin": 0,
  "vim_mode": true
}
