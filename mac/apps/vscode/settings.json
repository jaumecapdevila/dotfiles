  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "errorLens.excludeWorkspaces": ["/Users/capdevil/.dotfiles"],
  "explorer.confirmDelete": false,
  "explorer.decorations.badges": false,
  "extensions.ignoreRecommendations": true,
  "files.autoSave": "afterDelay",
  "files.insertFinalNewline": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "github.copilot.enable": {
    "*": true,
    "markdown": false,
    "plaintext": false,
    "scminput": false,
    "yaml": false
  },
  "material-icon-theme.activeIconPack": "none",
  "material-icon-theme.folders.color": "#C678DD",
  "material-icon-theme.folders.theme": "classic",
  "material-icon-theme.hidesExplorerArrows": true,
  "terminal.integrated.fontFamily": "'OperatorMono Nerd Font', monospace",
  "terminal.integrated.fontSize": 18,
  "terminal.integrated.smoothScrolling": true,
  "workbench.activityBar.location": "hidden",
  "workbench.colorCustomizations": {
    "[One Dark]": {
      "editorBracketHighlight.foreground1": "#D19A66",
      "editorBracketHighlight.foreground2": "#C678DD",
      "editorBracketHighlight.foreground3": "#56B6C2",
      "list.activeSelectionBackground": "#2c313a",
      "list.activeSelectionForeground": "#C678DD",
      "list.highlightForeground": "#C678DD"
    }
  },
  "workbench.colorTheme": "One Dark",
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "none",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.settings.editor": "json",
  "workbench.startupEditor": "none",
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.sideBar.location": "right"
}
