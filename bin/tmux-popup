#!/usr/bin/env bash

session="${1:-scratch}"
dimensions="${2:-80x75}"

active_session=$(tmux display-message -p -F "#{session_name}" 2>/dev/null)

if [ "$active_session" = "$session" ]; then
  tmux detach-client
else
  w=$(echo "$dimensions" | cut -d'x' -f1)
  h=$(echo "$dimensions" | cut -d'x' -f2)
  tmux popup -d '#{pane_current_path}' -xC -yC -w"$w"% -h"$h"% -E "tmux attach -t $session || tmux new -s $session"
fi
