#!/usr/bin/env bash

source "$DOTFILES_PATH/scripts/core/docs.sh"

##? Clears command history
#?? 1.0.0
##?
##? Usage:
##?    clear_history zsh      # Clears zsh history
##?    clear_history bash     # Clears bash history

docs::eval_help "$@"

HISTORY_FILE="$HOME/.zsh_history"
echo "Removing $HISTORY_FILE"
rm $HISTORY_FILE
echo "Done!"
